# Base
ENV=docker
DEBUG=True

# Database per Docker
DB_NAME=boardgamers
DB_USER=bg_user
DB_PASSWORD=bg_password
DB_HOST=db
DB_PORT=5432

# Percorsi Linux all'interno del container
GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so

# Opzionale: override degli allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
