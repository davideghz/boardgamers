# Ambiente
ENV=local
DEBUG=True

# Django
DJANGO_SECRET_KEY=your-weird-local-dummy-secret
DJANGO_SETTINGS_MODULE=boardGames.local_settings

# API / chiavi
MAPS_API_KEY=xxxxxxxxxx

# Google OAuth2
GOOGLE_OAUTH2_KEY=xxxxxxxxxx
GOOGLE_OAUTH2_SECRET=xxxxxxxxxx

# Email (es. Mailtrap per sviluppo)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_HOST_USER=xxxxxxxxxx
EMAIL_HOST_PASSWORD=xxxxxxxxxx
EMAIL_PORT=2525

# AWS S3
AWS_S3_ACCESS_KEY_ID=xxxxxxxxxx
AWS_S3_SECRET_ACCESS_KEY=xxxxxxxxxx

# AWS SES (opzionale se invii email)
AWS_SES_ACCESS_KEY_ID=xxxxxxxxxx
AWS_SES_SECRET_ACCESS_KEY=xxxxxxxxxx

# Google ReCaptcha
RECAPTCHA_PUBLIC_KEY=xxxxxxxxxx
RECAPTCHA_PRIVATE_KEY=xxxxxxxxxx

# Database
DB_NAME=boardgamers
DB_USER=bg_user
DB_PASSWORD=bg_password
DB_HOST=localhost #db if docker
DB_PORT=5432

# GDAL & GEOS Libraries
GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so